# Pick ONE provider. Groq is free and the default.
# ---------- Option A: Groq (free, recommended) ----------
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: rotate across multiple Groq keys (each account has its own
# 100K-tokens-per-day budget on the free tier). Comma-separated. Whichever
# key the agent is using will rotate to the next one when its daily quota
# is exhausted.
# GROQ_API_KEYS=gsk_first,gsk_second,gsk_third

# ---------- Option B: OpenAI (paid, optional) ----------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

