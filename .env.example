# Pick a primary provider with LLM_PROVIDER. The agent will use that one
# first, but ANY other provider whose keys are also set in this file becomes
# an automatic fallback when the primary is rate-limited or its daily
# quota is exhausted. So setting keys for two or three providers is the
# easiest way to never hit a hard rate-limit wall.

LLM_PROVIDER=groq

# ---------- Groq (free, recommended primary) ----------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: rotate across multiple Groq keys (each free account has its
# own 100K-tokens-per-day budget). Comma-separated.
# GROQ_API_KEYS=gsk_first,gsk_second,gsk_third

# ---------- Gemini (free) ----------
# GEMINI_API_KEY=your_gemini_key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_KEYS=AIza_first,AIza_second

# ---------- OpenRouter (free models available) ----------
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_API_KEYS=sk-or-first,sk-or-second

# ---------- OpenAI (paid) ----------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEYS=sk-first,sk-second
